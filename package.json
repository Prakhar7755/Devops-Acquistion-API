{
  "name": "production-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "imports": {
    "#config/*": "./src/config/*",
    "#controllers/*": "./src/controllers/*",
    "#models/*": "./src/models/*",
    "#middleware/*": "./src/middleware/*",
    "#utils/*": "./src/utils/*",
    "#services/*": "./src/services/*",
    "#validations/*": "./src/validations/*",
    "#routes/*": "./src/routes/*"
  },
  "scripts": {
    "start": "node --watch  --trace-warnings src/index.js",
    "dev": "nodemon src/index.js",
    "build": "npm run build:dev:local",
    "build:dev:local": "docker compose --env-file .env.development -f docker-compose.dev.yml --profile dev build",
    "docker:dev": "docker compose --env-file .env.development -f docker-compose.dev.yml --profile dev up",
    "docker:dev:down": "docker compose --env-file .env.development -f docker-compose.dev.yml --profile dev down",
    "docker:dev:logs": "docker compose --env-file .env.development -f docker-compose.dev.yml --profile dev logs -f",
    "docker:dev:build:up": "npm run build:dev:local && npm run docker:dev",
    "build:prod": "docker compose --env-file .env.production -f docker-compose.prod.yml --profile prod build",
    "docker:prod": "docker compose --env-file .env.production -f docker-compose.prod.yml --profile prod up -d",
    "docker:prod:down": "docker compose --env-file .env.production -f docker-compose.prod.yml --profile prod down",
    "docker:logs": "docker compose --env-file .env.production -f docker-compose.prod.yml --profile prod logs -f",
    "neon:local": "docker compose --env-file .env.development -f docker-compose.neon.yml up",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@arcjet/inspect": "^1.4.0",
    "@arcjet/node": "^1.4.0",
    "@neondatabase/serverless": "^1.1.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^4.22.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.21.0",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3"
  }
}
